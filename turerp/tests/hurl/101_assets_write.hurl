# 101_assets_write — WRITE-FENCE for the Fixed Assets mutation surface.
#
# Covers the full soft-delete lifecycle for assets, plus the status
# transitions, depreciation, dispose/write-off, maintenance start/end,
# and maintenance-record CRUD that the read-only 32_assets.hurl leaves
# uncovered (list/by-id/404/RBAC-403 only).
#
# Lifecycle:
#   asset       : POST create → GET /deleted → GET /status/{status}
#                 → GET /{id} → PUT /{id} → PUT /{id}/status
#                 → POST /{id}/depreciation → POST /{id}/depreciation/record
#                 → POST /{id}/maintenance/start → POST /{id}/maintenance/end
#                 → POST /{id}/dispose → (status=disposed) → DELETE soft
#                 → GET 404 → PUT /restore → GET 200 → DELETE /destroy
#                 → GET 404
#   maintenance : POST /assets/maintenance-records → GET /{id}/maintenance-records
#
# RBAC: writes use the AdminUser extractor → testuser ({{access_token}})
# gets 403, admin ({{admin_token}}) gets 200/201. Reads use AuthUser → any
# authed 200, no-auth 401. run-all.sh SKIPS this file when admin_token empty.
#
# FK STRATEGY: assets are self-contained (POST /assets; asset_code is
# generated by the repo as AST-<timestamp_ms>, so no uniqueness collision
# across re-runs). maintenance-records need asset_id → self-seed an asset,
# capture id. dispose/write-off/depreciation/maintenance all take the
# self-seeded asset_id.
#
# ASSUMPTION: AssetStatus has #[serde(rename_all = "lowercase")] so the
# JSON body/status-path uses lowercase variants: "active", "inuse",
# "undermaintenance", "disposed", "writtenoff". The Display impl writes
# PascalCase ("Active") which is what the DB stores; parse_asset_status
# maps both directions. Response $.status is the serde-serialized enum
# value → "active"/"undermaintenance"/"disposed".
# ASSUMPTION: DepreciationMethod similarly uses rename_all = "lowercase"
# ("straightline"). The create body sends "depreciation_method":
# "straightline"; response $.depreciation_method == "straightline".
# ASSUMPTION: rust_decimal deserializes from JSON strings for
# acquisition_cost / salvage_value / depreciation amount. If Decimal serde
# is configured to require a number, step 3 will 400 — flagged.
# ASSUMPTION: acquisition_date is a chrono::DateTime<Utc> deserialized
# from an ISO-8601 string ("2024-01-01T00:00:00Z").
# ASSUMPTION: create_asset returns the full Asset (not AssetResponse) —
# the response includes deleted_at:null and deleted_by:null; we assert
# $.status == "active" and $.asset_code starts with "AST-".
# ASSUMPTION: end_maintenance rejects any new_status that is not Active or
# InUse (service.rs line 165) → step using "disposed" would 400; we send
# "active".
# ASSUMPTION: GET /assets/status/{status} deserializes the path via serde
# (rename_all lowercase) → "active" resolves; "bogus" 404s (per
# 32_assets.hurl step 3).
# ASSUMPTION: dispose_asset sets status=Disposed; a subsequent
# write_off_asset on the same asset would overwrite to WrittenOff — we
# exercise dispose only, then soft-delete (which is allowed in any status).

# --- 1. RBAC: regular user POST asset → 403 ---
POST {{base_url}}/api/v1/assets
Authorization: Bearer {{access_token}}
Content-Type: application/json
```
{
  "tenant_id": {{tenant_id}},
  "company_id": 1,
  "name": "should be forbidden",
  "acquisition_date": "2024-01-01T00:00:00Z",
  "acquisition_cost": "1000.00",
  "salvage_value": "100.00",
  "useful_life_years": 5,
  "depreciation_method": "straightline"
}
```
HTTP 403

# --- 2. RBAC: no-auth POST asset → 401 ---
POST {{base_url}}/api/v1/assets
Content-Type: application/json
```
{
  "tenant_id": {{tenant_id}},
  "company_id": 1,
  "name": "should be unauth",
  "acquisition_date": "2024-01-01T00:00:00Z",
  "acquisition_cost": "1000.00",
  "salvage_value": "100.00",
  "useful_life_years": 5,
  "depreciation_method": "straightline"
}
```
HTTP 401

# --- 3. Admin POST /assets → 201; capture asset_id ---
POST {{base_url}}/api/v1/assets
Authorization: Bearer {{admin_token}}
Content-Type: application/json
```
{
  "tenant_id": {{tenant_id}},
  "company_id": 1,
  "name": "Hurl Test Asset",
  "description": "write-fence seeded asset",
  "serial_number": "HURL-SN-001",
  "location": "Istanbul",
  "acquisition_date": "2024-01-01T00:00:00Z",
  "acquisition_cost": "10000.00",
  "salvage_value": "1000.00",
  "useful_life_years": 5,
  "depreciation_method": "straightline",
  "notes": "hurl fence"
}
```
HTTP 201
[Captures]
asset_id: jsonpath "$.id"
[Asserts]
jsonpath "$.id" isNumber
jsonpath "$.asset_code" isString
jsonpath "$.name" == "Hurl Test Asset"
jsonpath "$.status" == "active"
jsonpath "$.depreciation_method" == "straightline"
jsonpath "$.acquisition_cost" exists
jsonpath "$.book_value" exists
jsonpath "$.accumulated_depreciation" exists
jsonpath "$.created_at" exists
jsonpath "$.deleted_at" == null

# --- 4. GET /assets/deleted (admin) — decode fence: bare Vec (empty pre-delete) ---
GET {{base_url}}/api/v1/assets/deleted
Authorization: Bearer {{admin_token}}
HTTP 200
[Asserts]
jsonpath "$" isCollection

# --- 5. GET /assets/status/active — decode fence: bare Vec, seeded row present ---
GET {{base_url}}/api/v1/assets/status/active
Authorization: Bearer {{admin_token}}
HTTP 200
[Asserts]
jsonpath "$" isCollection
jsonpath "$[0].id" isNumber
jsonpath "$[0].status" == "active"

# --- 6. GET /assets/{id} — decode fence: single Asset ---
GET {{base_url}}/api/v1/assets/{{asset_id}}
Authorization: Bearer {{admin_token}}
HTTP 200
[Asserts]
jsonpath "$.id" == {{asset_id}}
jsonpath "$.name" == "Hurl Test Asset"
jsonpath "$.status" == "active"
jsonpath "$.depreciation_method" == "straightline"
jsonpath "$.useful_life_years" == 5
jsonpath "$.tenant_id" isNumber
jsonpath "$.company_id" isNumber
jsonpath "$.created_at" exists

# --- 7. PUT /assets/{id} — 200; changed name reflects ---
PUT {{base_url}}/api/v1/assets/{{asset_id}}
Authorization: Bearer {{admin_token}}
Content-Type: application/json
```
{
  "name": "Hurl Test Asset (renamed)",
  "location": "Ankara",
  "notes": "renamed by hurl fence"
}
```
HTTP 200
[Asserts]
jsonpath "$.id" == {{asset_id}}
jsonpath "$.name" == "Hurl Test Asset (renamed)"
jsonpath "$.location" == "Ankara"

# --- 8. PUT /assets/{id}/status → 200; status reflects ---
PUT {{base_url}}/api/v1/assets/{{asset_id}}/status
Authorization: Bearer {{admin_token}}
Content-Type: application/json
```
{ "status": "inuse" }
```
HTTP 200
[Asserts]
jsonpath "$.id" == {{asset_id}}
jsonpath "$.status" == "inuse"

# --- 9. POST /assets/{id}/depreciation → 200 (calculate+record annual) ---
POST {{base_url}}/api/v1/assets/{{asset_id}}/depreciation
Authorization: Bearer {{admin_token}}
HTTP 200
[Asserts]
jsonpath "$.id" == {{asset_id}}
jsonpath "$.accumulated_depreciation" exists
jsonpath "$.book_value" exists

# --- 10. POST /assets/{id}/depreciation/record → 200 (manual amount) ---
POST {{base_url}}/api/v1/assets/{{asset_id}}/depreciation/record
Authorization: Bearer {{admin_token}}
Content-Type: application/json
```
{ "amount": "500.00" }
```
HTTP 200
[Asserts]
jsonpath "$.id" == {{asset_id}}
jsonpath "$.accumulated_depreciation" exists

# --- 11. POST /assets/{id}/maintenance/start → 200 (status→undermaintenance) ---
POST {{base_url}}/api/v1/assets/{{asset_id}}/maintenance/start
Authorization: Bearer {{admin_token}}
HTTP 200
[Asserts]
jsonpath "$.id" == {{asset_id}}
jsonpath "$.status" == "undermaintenance"

# --- 12. POST /assets/{id}/maintenance/end → 200 (new_status=active) ---
POST {{base_url}}/api/v1/assets/{{asset_id}}/maintenance/end
Authorization: Bearer {{admin_token}}
Content-Type: application/json
```
{ "new_status": "active" }
```
HTTP 200
[Asserts]
jsonpath "$.id" == {{asset_id}}
jsonpath "$.status" == "active"

# --- 13. POST /assets/maintenance-records → 201; capture record_id ---
POST {{base_url}}/api/v1/assets/maintenance-records
Authorization: Bearer {{admin_token}}
Content-Type: application/json
```
{
  "asset_id": {{asset_id}},
  "maintenance_date": "2024-06-01T00:00:00Z",
  "maintenance_type": "Preventive",
  "description": "hurl fence maintenance record",
  "cost": "250.00",
  "performed_by": "hurl-tech",
  "next_maintenance_date": "2024-12-01T00:00:00Z"
}
```
HTTP 201
[Captures]
record_id: jsonpath "$.id"
[Asserts]
jsonpath "$.id" isNumber
jsonpath "$.asset_id" == {{asset_id}}
jsonpath "$.maintenance_type" == "Preventive"
jsonpath "$.cost" exists

# --- 14. GET /assets/{id}/maintenance-records — decode fence: bare Vec ---
GET {{base_url}}/api/v1/assets/{{asset_id}}/maintenance-records
Authorization: Bearer {{admin_token}}
HTTP 200
[Asserts]
jsonpath "$" isCollection
jsonpath "$[0].id" isNumber
jsonpath "$[0].asset_id" == {{asset_id}}

# --- 15. POST /assets/{id}/dispose → 200 (status→disposed) ---
POST {{base_url}}/api/v1/assets/{{asset_id}}/dispose
Authorization: Bearer {{admin_token}}
HTTP 200
[Asserts]
jsonpath "$.id" == {{asset_id}}
jsonpath "$.status" == "disposed"

# --- 16. RBAC: no-auth GET asset → 401 ---
GET {{base_url}}/api/v1/assets/{{asset_id}}
HTTP 401

# --- 17. DELETE /assets/{id} (soft) → 200 MessageResponse ---
DELETE {{base_url}}/api/v1/assets/{{asset_id}}
Authorization: Bearer {{admin_token}}
HTTP 200
[Asserts]
jsonpath "$.message" exists

# --- 18. GET /assets/{id} after soft-delete → 404 ---
GET {{base_url}}/api/v1/assets/{{asset_id}}
Authorization: Bearer {{admin_token}}
HTTP 404
[Asserts]
jsonpath "$.error" exists

# --- 19. PUT /assets/{id}/restore → 200 ---
PUT {{base_url}}/api/v1/assets/{{asset_id}}/restore
Authorization: Bearer {{admin_token}}
HTTP 200
[Asserts]
jsonpath "$.id" == {{asset_id}}
jsonpath "$.name" == "Hurl Test Asset (renamed)"

# --- 20. GET /assets/{id} after restore → 200 ---
GET {{base_url}}/api/v1/assets/{{asset_id}}
Authorization: Bearer {{admin_token}}
HTTP 200
[Asserts]
jsonpath "$.id" == {{asset_id}}
jsonpath "$.status" == "disposed"

# --- 21. DELETE /assets/{id}/destroy → 204 (hard delete) ---
DELETE {{base_url}}/api/v1/assets/{{asset_id}}/destroy
Authorization: Bearer {{admin_token}}
HTTP 204

# --- 22. GET /assets/{id} after destroy → 404 ---
GET {{base_url}}/api/v1/assets/{{asset_id}}
Authorization: Bearer {{admin_token}}
HTTP 404
[Asserts]
jsonpath "$.error" exists